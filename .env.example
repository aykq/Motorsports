# Database
POSTGRES_DB=motorsports
POSTGRES_USER=ms_user
POSTGRES_PASSWORD=change_this_strong_password

# Auth.js
AUTH_SECRET=                    # openssl rand -base64 32
AUTH_GOOGLE_ID=                 # Google Cloud Console > OAuth 2.0 Client ID
AUTH_GOOGLE_SECRET=             # Google Cloud Console > OAuth 2.0 Client Secret
AUTH_RESEND_KEY=                # resend.com API key (magic link için)

# Web Push (VAPID)
VAPID_PUBLIC_KEY=               # npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=   # same as VAPID_PUBLIC_KEY (client-side access)
VAPID_PRIVATE_KEY=              # npx web-push generate-vapid-keys
VAPID_EMAIL=mailto:your@email.com

# Cron güvenlik
CRON_SECRET=                    # openssl rand -base64 32

# Uygulama
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Gemini API (yarış olayları çevirisi)
GEMINI_API_KEY=                 # aistudio.google.com/app/apikey
GEMINI_MODEL=

# Drizzle ORM (otomatik oluşturulur, değiştirme)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
